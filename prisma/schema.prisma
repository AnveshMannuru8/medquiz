generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String        @id @default(cuid())
  name            String?
  email           String        @unique
  passwordHash    String?
  role            String        @default("STUDENT")
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime      @default(now())
  accounts        Account[]
  sessions        Session[]
  subscription    Subscription?
  quizSessions    QuizSession[]
  flashcards      Flashcard[]
  notes           Note[]
  affiliate       Affiliate?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Question {
  id                  String   @id @default(cuid())
  qid                 String   @unique // Auto-generated (e.g., QID-1001)
  subject             String   // e.g., Pathology
  topic               String   // e.g., Cardiovascular
  subtopic            String   // e.g., Ischemic Heart Disease
  difficulty          String   // EASY | MEDIUM | HARD
  questionText        String   @db.Text
  questionImageUrl    String?  // Image for the question
  choices             Json     // [{id: string, text: string, isCorrect: boolean}]
  explanationText     String   @db.Text
  explanationImageUrl String?  // Image for the explanation
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  answers             QuizAnswer[]
}

model QuizSession {
  id            String       @id @default(cuid())
  userId        String
  mode          String       // TUTOR | EXAM
  status        String       // ACTIVE | COMPLETED | PAUSED
  timeLimitSecs Int?
  score         Float?
  createdAt     DateTime     @default(now())
  completedAt   DateTime?
  user          User         @relation(fields:[userId], references:[id])
  answers       QuizAnswer[]
}

model QuizAnswer {
  id            String       @id @default(cuid())
  sessionId     String
  questionId    String
  userId        String
  choiceId      String
  isCorrect     Boolean
  timeSpentSecs Int?
  createdAt     DateTime     @default(now())
  session       QuizSession  @relation(fields:[sessionId], references:[id])
  question      Question     @relation(fields:[questionId], references:[id])
}

model Plan {
  id            String   @id @default(cuid())
  name          String   // e.g., "1 Month", "6 Months"
  price         Float    // e.g., 49.99
  stripePriceId String?  
  features      String[] 
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeCustomerId     String   @unique
  stripeSubscriptionId String?  @unique
  status               String   // ACTIVE, PAST_DUE, CANCELED
  currentPeriodEnd     DateTime
  user                 User     @relation(fields: [userId], references: [id])
}

model Flashcard {
  id             String   @id @default(cuid())
  userId         String
  front          String
  back           String
  sourceType     String?  // 'question' | 'note' | 'manual' | 'ai'
  // SM-2 spaced repetition fields
  nextReviewAt   DateTime @default(now())
  interval       Int      @default(1)   // days
  easeFactor     Float    @default(2.5)
  repetitions    Int      @default(0)
  user           User     @relation(fields:[userId], references:[id])
}

model Note {
  id             String   @id @default(cuid())
  userId         String
  content        String
  createdAt      DateTime @default(now())
  user           User     @relation(fields:[userId], references:[id])
}

model Affiliate {
  id           String   @id @default(cuid())
  userId       String   @unique
  referralCode String   @unique
  clicks       Int      @default(0)
  conversions  Int      @default(0)
  earnings     Float    @default(0.0)
  user         User     @relation(fields:[userId],references:[id])
}